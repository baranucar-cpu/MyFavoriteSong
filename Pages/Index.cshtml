@page
@model IndexModel
@{
    ViewData["Title"] = "My Favorite Song";
}

<h1>My Favorite Song</h1>

<iframe width="560" height="315"
        src="https://www.youtube.com/embed/0ZyA8Fz0xvE"
        frameborder="0" allowfullscreen>
</iframe>

<div id="box"></div>

<style>
    #box {
        width: 100px;
        height: 100px;
        background-color: red;
        position: relative;
    }
</style>

<script>
    let box = document.getElementById("box");
    let position = 0;
    let direction = 1;

    setInterval(() => {
        position += 2 * direction;
        box.style.left = position + "px";

        if (position >= 300 || position <= 0) {
            direction *= -1;
        }
    }, 10);
</script>
